---
import Presentation from '../layouts/Presentation.astro';
import Cover    from '../components/slides/Cover.astro';
import Content  from '../components/slides/Content.astro';
import Stat     from '../components/slides/Stat.astro';
import Closing  from '../components/slides/Closing.astro';
---
<Presentation title="IA en tu trabajo — ALVS Capacitación">

  <Cover
    title="Inteligencia Artificial en tu trabajo"
    subtitle="Cómo usar IA para trabajar mejor, más rápido y con más confianza."
    meta="ALVS Group · Capacitación interna · 2026"
  />

  <Content title="¿Qué vamos a ver hoy?" accent="hoy">
    <ul class="space-y-5 list-none">
      {[
        'Qué es la IA y qué no es',
        'Herramientas que ya podés usar ahora',
        'Casos reales dentro de ALVS',
        'Límites, riesgos y buenas prácticas',
        'Espacio de preguntas y práctica',
      ].map(item => (
        <li class="flex items-start gap-4">
          <span style="color:var(--color-alvs-cyan); flex-shrink:0;">→</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </Content>

  <Stat
    stat="73%"
    label="de los trabajos van a cambiar con la IA"
    context="No desaparecer — cambiar. La diferencia la hace quién se prepara."
  />

  <Content title="Lo que la IA hace bien" accent="bien">
    <div class="grid grid-cols-2 gap-6 h-full">
      {[
        { icon: '✍️', text: 'Redactar y resumir textos' },
        { icon: '🔍', text: 'Buscar y organizar información' },
        { icon: '📊', text: 'Analizar datos y encontrar patrones' },
        { icon: '💬', text: 'Responder preguntas complejas' },
      ].map(({ icon, text }) => (
        <div
          class="flex items-center gap-4 rounded-xl p-5"
          style="background-color: var(--color-alvs-surface);"
        >
          <span class="text-4xl">{icon}</span>
          <span style="font-size: var(--text-slide-body);">{text}</span>
        </div>
      ))}
    </div>
  </Content>

  <Closing
    message="¿Preguntas?"
    contact="capacitacion@alvsgroup.com"
  />

</Presentation>
