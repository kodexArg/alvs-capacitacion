---
interface Props {
  message?: string;
  contact?: string;
}
const {
  message = '¿Preguntas?',
  contact,
} = Astro.props;
---
<section
  data-slide
  class="slide items-center justify-center text-center"
  style="background: linear-gradient(135deg, var(--color-alvs-navy) 0%, var(--color-alvs-dark) 70%);"
>
  <div class="flex flex-col items-center gap-6 max-w-3xl mx-auto">
    <!-- Geometric accent (mirrors logo) -->
    <div class="flex gap-2 mb-4">
      <div class="w-3 h-3 bg-[color:var(--color-alvs-blue)] rotate-45"></div>
      <div class="w-3 h-3 bg-[color:var(--color-alvs-cyan)] rotate-45"></div>
      <div class="w-3 h-3 bg-[color:var(--color-alvs-blue)] rotate-45"></div>
    </div>

    <h2
      class="font-bold text-[color:var(--color-alvs-white)] leading-tight"
      style="font-size: var(--text-slide-hero);"
    >
      {message}
    </h2>

    <div class="accent-line mx-auto"></div>

    {contact && (
      <p
        class="text-[color:var(--color-alvs-cyan)]"
        style="font-size: var(--text-slide-body);"
      >
        {contact}
      </p>
    )}

    <p
      class="text-[color:var(--color-alvs-muted)] mt-8"
      style="font-size: var(--text-slide-caption);"
    >
      ALVS Group · Creando nuevas oportunidades, cada día.
    </p>
  </div>
</section>
